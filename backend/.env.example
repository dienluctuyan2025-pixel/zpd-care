GOOGLE_API_KEY=your_gemini_api_key_here

# CORS: localhost Next mặc định. Demo LAN: ALLOWED_ORIGINS=*
# Production: http://localhost:3000,http://192.168.x.x:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MAX_UPLOAD_MB=25

# Auth (HMAC JWT) — BẮT BUỘC đổi trong production
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_SECONDS=43200

# Chỉ bật 1 khi debug local (mở API không login) — KHÔNG dùng production
AUTH_DISABLED=0
